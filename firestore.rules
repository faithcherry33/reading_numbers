rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 이 게임은 Firebase 익명 로그인을 사용합니다.
    // 교실용 프로토타입 규칙으로, 로그인한 사용자가 실시간 대결 문서를 갱신할 수 있습니다.
    // 상금·공식 기록처럼 조작 방지가 중요한 서비스라면 점수 처리를 Cloud Functions로 옮기세요.

    match /numberReadingRooms/{roomId}/presence/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    match /numberReadingMatches/{roomId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
